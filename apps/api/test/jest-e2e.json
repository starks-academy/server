{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/common(|/.*)$": "<rootDir>/../../libs/common/src/$1",
    "^@app/database(|/.*)$": "<rootDir>/../../libs/database/src/$1",
    "^@app/config(|/.*)$": "<rootDir>/../../libs/config/src/$1"
  }
}
