{
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "entryFile": "main",
  "monorepo": true,
  "defaultProject": "api",
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    }
  },
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "tsconfig.json"
  },
  "generateOptions": {
    "spec": true
  }
}
